# .env.example — Consensus
# Copy to .env (gitignored). Never commit secrets. In prod, use service-specific env config.

# --- Shared (auth) ---
NODE_ENV=development
APP_URL=http://localhost:3000
JWT_ACCESS_SECRET=change-me-to-at-least-32-characters!!
JWT_REFRESH_SECRET=change-me-to-at-least-32-characters!!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- Database (state + audit + checkpoints) ---
# Local: docker-compose Postgres
DATABASE_URL=postgresql://consensus:consensus@localhost:5432/consensus
# Production: Supabase connection string
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# --- Redis (agent job queue) ---
# Local: docker-compose Redis
REDIS_URL=redis://localhost:6379
# Production: Upstash Redis
# UPSTASH_REDIS_REST_URL=https://[id].upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Gateway ---
GATEWAY_URL=http://localhost:8000

# --- LLM (env-configurable per PLAYBOOK §5) ---
LLM_API_KEY=your-gemini-api-key
LLM_MODEL_SUPERVISOR=gemini-2.5-flash
LLM_MODEL_SPECIALIST=gemini-2.5-flash

# --- Loop / budget ceilings ---
MAX_STEPS_PER_RUN=25
MAX_TOOL_CALLS_PER_RUN=40
COST_CEILING_USD_PER_RUN=1.50

# --- Tracing (Langfuse Cloud) ---
LANGFUSE_PUBLIC_KEY=your-langfuse-public
LANGFUSE_SECRET_KEY=your-langfuse-secret
LANGFUSE_HOST=https://cloud.langfuse.com

# --- MCP tool servers ---
MCP_SEARCH_URL=http://localhost:9001
MCP_DOCS_URL=http://localhost:9002
MCP_INTERNAL_DATA_URL=http://localhost:9003
# Consequential tools require approval — enforced in the graph, not here.

# --- Billing (stub) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email ---
EMAIL_FROM=noreply@consensus.app
EMAIL_PROVIDER_KEY=your-email-provider-key
